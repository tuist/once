{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fabrik-docs",
  "compatibility_date": "2026-05-12",
  "workers_dev": false,
  "preview_urls": true,
  "route": {
    "pattern": "fabrik.run/*",
    "zone_name": "fabrik.run"
  },
  "assets": {
    "directory": "./.vitepress/dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
