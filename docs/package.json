{
  "name": "@once/docs",
  "version": "0.1.0",
  "description": "Documentation site for Once",
  "private": true,
  "devDependencies": {
    "vitepress": "^1.6.4",
    "wrangler": "4.90.1"
  },
  "scripts": {
    "dev": "vitepress dev",
    "build:reference": "cd .. && cargo build --release -p once-cli && rm -rf docs/reference/cli docs/reference/mcp/tools.md && ./target/release/once reference --out docs/reference",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "deploy": "wrangler deploy"
  },
  "aube": {
    "allowBuilds": {
      "esbuild": true,
      "sharp": true,
      "workerd": true
    }
  }
}
