---
layout: layouts/base.njk
title: "Blog"
description: "Updates from the Fabrik project."
permalink: "/blog/"
---

{% from "partials/icons.njk" import icon %}

<section class="fabrik-page">
  <div class="fabrik-container">
    <header class="fabrik-section-header" data-align="left">
      <span data-part="eyebrow">Blog</span>
      <h1 data-part="title">Updates from the workshop.</h1>
      <p data-part="lede">
        Release notes, design decisions, and field notes from building Fabrik.
      </p>
    </header>

    <div class="fabrik-post-list">
      {% for post in collections.posts %}
        <a href="{{ post.url }}">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          <span data-part="title">{{ post.data.title }}</span>
          {% if post.data.description %}
            <p>{{ post.data.description }}</p>
          {% endif %}
          <span data-part="cta">
            Read post
            {{ icon("arrow-right", 14) }}
          </span>
        </a>
      {% else %}
        <p data-part="empty">No posts yet. Check back soon.</p>
      {% endfor %}
    </div>
  </div>
</section>
