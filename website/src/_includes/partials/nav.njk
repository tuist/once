{% from "partials/icons.njk" import icon %}

<header class="once-nav">
  <div class="once-container">
    <div data-part="inner">
      <a href="/" data-part="brand">
        <img src="/logo.png" alt="" />
        <span>{{ copy.nav.brand }}</span>
      </a>

      <nav data-part="links" aria-label="{{ copy.nav.primary.label }}">
        {% for item in copy.nav.primary.items %}
          <a href="{{ item.href }}">{{ item.text }}</a>
        {% endfor %}
      </nav>

      <div data-part="actions">
        <a href="{{ copy.nav.ctaSecondary.href }}" class="once-button" data-variant="secondary">{{ copy.nav.ctaSecondary.text }}</a>
        <a href="{{ copy.nav.ctaPrimary.href }}" class="once-button" data-variant="primary">
          {{ icon("github", 14) }}
          {{ copy.nav.ctaPrimary.text }}
        </a>
      </div>
    </div>
  </div>
</header>
