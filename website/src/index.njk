---
layout: layouts/base.njk
title: "Once: a polyglot automation kernel for humans and agents"
description: "Once sits between your team, their agents, and the infrastructure that runs their code. Cache hits, remote runners, and toolchains, all behind one graph."
homepage: true
---

{% from "partials/icons.njk" import icon, langMark %}

<section class="once-section" data-tone="hero">
  <div data-part="glow"></div>
  <div class="once-container">
    <div class="once-hero">
      <div data-part="copy">
        <div data-part="badges">
          <span class="once-badge">
            <span data-part="dot"></span>
            {{ copy.home.hero.badge }}
          </span>
          <a href="{{ copy.home.hero.bylineHref }}" class="once-byline" rel="noopener">
            <span data-part="mark">
              <svg width="14" height="14" viewBox="0 0 512 512" aria-hidden="true">
                <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M126.933 369.951C126.933 369.951 180.8 412.8 257.6 412.8C334.4 412.8 388.267 369.951 388.267 369.951" stroke-width="30"/>
                  <path d="M112 297.21C112 297.21 205.333 409.6 257.6 409.6C309.867 409.6 403.201 297.21 403.201 297.21" stroke-width="30"/>
                  <path d="M112 207.297C112 207.297 205.333 409.6 257.6 409.6C309.867 409.6 403.201 207.297 403.201 207.297" stroke-width="30"/>
                  <path d="M171.734 128.624C171.734 128.624 230.4 409.6 257.6 409.6C284.8 409.6 343.466 128.624 343.466 128.624" stroke-width="30"/>
                  <path d="M258.667 409.6V102.4" stroke-width="30"/>
                  <rect x="20" y="20" width="472" height="472" rx="236" stroke-width="32"/>
                </g>
              </svg>
            </span>
            {{ copy.home.hero.byline }}
            <span data-part="arrow">{{ icon("arrow-right", 12) }}</span>
          </a>
        </div>
        <h1 data-part="title">{{ copy.home.hero.title }}</h1>
        <p data-part="subtitle">{{ copy.home.hero.subtitle }}</p>
        <div data-part="actions">
          {% for action in copy.home.hero.actions %}
            <a href="{{ action.href }}" class="once-button" data-variant="{{ action.variant }}" data-size="large">
              {% if action.icon == "github" %}{{ icon("github", 16) }}{% endif %}
              {{ action.text }}
              {% if action.icon == "arrow-right" %}{{ icon("arrow-right", 16) }}{% endif %}
            </a>
          {% endfor %}
        </div>
      </div>

      <div data-part="visual">
        <div class="once-terminal">
          <div data-part="header">
            <span data-part="dots"><span></span><span></span><span></span></span>
            <span data-part="title">{{ copy.home.hero.terminal.title }}</span>
          </div>
          <pre data-part="body">{{ copy.home.hero.terminal.body | trim | terminalHtml | safe }}</pre>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="once-section">
  <div class="once-container">
    <div class="once-narrative">
      <header data-part="header">
        <span data-part="eyebrow">{{ copy.home.why.eyebrow }}</span>
        <h2 data-part="title">{{ copy.home.why.title }}</h2>
      </header>

      {% for beat in copy.home.why.beats %}
        <div data-part="beat">
          <h3>{{ beat.heading }}</h3>
          {% for p in beat.paragraphs %}
            <p>{{ p }}</p>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="once-section">
  <div class="once-container">
    <div class="once-split">
      <div>
        <span data-part="eyebrow">{{ copy.home.howItWorks.eyebrow }}</span>
        <h2 data-part="title">{{ copy.home.howItWorks.title }}</h2>
        <p data-part="lede">{{ copy.home.howItWorks.lede }}</p>
        <ul data-part="bullets">
          {% for bullet in copy.home.howItWorks.bullets %}
            <li>
              {{ icon("check") }}
              <span>{{ bullet | inlineMd | safe }}</span>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="once-terminal">
        <div data-part="header">
          <span data-part="dots"><span></span><span></span><span></span></span>
          <span data-part="title">{{ copy.home.howItWorks.snippet.filename }}</span>
        </div>
        <pre data-part="body">{{ copy.home.howItWorks.snippet.body | trim | tomlHighlight | safe }}</pre>
      </div>
    </div>
  </div>
</section>

<section class="once-section">
  <div class="once-container">
    <header class="once-section-header">
      <span data-part="eyebrow">{{ copy.home.faq.eyebrow }}</span>
      <h2 data-part="title">{{ copy.home.faq.title }}</h2>
    </header>

    <div class="once-faq">
      {% for faq in copy.home.faq.items %}
        <details>
          <summary>
            <span>{{ faq.q }}</span>
            <span data-part="icon">{{ icon("plus") }}</span>
          </summary>
          <p data-part="answer">{{ faq.a }}</p>
        </details>
      {% endfor %}
    </div>
  </div>
</section>

<section class="once-section">
  <div class="once-container">
    <div class="once-cta-panel">
      <h2 data-part="title">{{ copy.home.cta.title }}</h2>
      <p data-part="lede">{{ copy.home.cta.lede | inlineMd | safe }}</p>
      <div data-part="actions">
        {% for action in copy.home.cta.actions %}
          <a href="{{ action.href }}" class="once-button" data-variant="{{ action.variant }}" data-size="large">
            {% if action.icon == "github" %}{{ icon("github", 16) }}{% endif %}
            {{ action.text }}
            {% if action.icon == "arrow-right" %}{{ icon("arrow-right", 16) }}{% endif %}
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
