{
  "name": "@fabrik/website",
  "version": "0.1.0",
  "description": "Marketing site and blog for Fabrik",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "eleventy --serve --quiet",
    "build": "eleventy",
    "clean": "rm -rf _site",
    "deploy": "wrangler deploy",
    "social:images": "node scripts/generate-social-images.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-rss": "^2.0.2",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "sharp": "^0.34.5",
    "wrangler": "4.90.1"
  },
  "aube": {
    "allowBuilds": {
      "sharp": true,
      "esbuild": true,
      "workerd": true
    }
  }
}
